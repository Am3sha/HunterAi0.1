# HunterAI backend configuration (Sprint 0)
# Copy to `.env` and adjust. Never commit `.env`.

# --- App ---
HUNTERAI_APP_NAME=HunterAI
HUNTERAI_ENV=development
HUNTERAI_DEBUG=true

# --- API ---
HUNTERAI_API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins (Next.js dev server by default)
HUNTERAI_CORS_ORIGINS=http://localhost:3000

# --- Managed tools ---
# Where the Tool Manager installs downloaded security-tool binaries.
# Kept out of git. Defaults to <repo>/.hunterai/tools if unset.
# HUNTERAI_TOOLS_DIR=/home/youruser/.hunterai/tools

# --- Database ---
# Synchronous SQLAlchemy URL (psycopg v3 driver).
HUNTERAI_DATABASE_URL=postgresql+psycopg://hunterai:hunterai@localhost:5432/hunterai
